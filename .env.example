# Database (Supabase Postgres, dùng cho Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"
DIRECT_URL="postgresql://postgres:password@localhost:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxx"
SUPABASE_SERVICE_ROLE_KEY="xxxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# VNPay (sandbox)
VNPAY_TMN_CODE="xxxxx"
VNPAY_HASH_SECRET="xxxxx"
VNPAY_PAYMENT_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/api/webhooks/vnpay"

# MoMo (sandbox)
MOMO_PARTNER_CODE="xxxxx"
MOMO_ACCESS_KEY="xxxxx"
MOMO_SECRET_KEY="xxxxx"
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_REDIRECT_URL="http://localhost:3000/checkout/result"
MOMO_IPN_URL="http://localhost:3000/api/webhooks/momo"

# Email (Resend)
RESEND_API_KEY="xxxxx"
EMAIL_FROM="no-reply@example.com"

# YouTube (Phase 1 video)
NEXT_PUBLIC_YOUTUBE_API_KEY="xxxxx"
